      "query": "string — the raw query as a user would type it",
      "expected_bypass": "bool — whether Layer 0 SHOULD bypass this query",
      "expected_category": "string|null — one of: trivial_greeting, trivial_acknowledgment, trivial_farewell, pure_arithmetic, simple_definition, simple_factual, malformed, none",
      "expected_language": "string|null — ISO-639-1 language code if known",
      "rationale": "string — why this is the correct label (one short sentence)",
      "source": "string — where this query came from: 'curated', 'audit', 'reviewer_feedback', 'real_log', 'adversarial'"
    },
    "summary_by_category": {
      "trivial_greeting": "expected_bypass=true; greetings/hello variants in multiple languages",
      "trivial_acknowledgment": "expected_bypass=true; thanks/ok/got-it in multiple languages",
      "trivial_farewell": "expected_bypass=true; bye/goodbye in multiple languages",
      "pure_arithmetic": "expected_bypass=true; pure math expressions with operators",
      "simple_factual": "expected_bypass=true; capital-of-X / define-X / president-of-Y",
      "malformed": "expected_bypass=true; pure punctuation, repeated noise — bypass to cheap chat",
      "none_real_question": "expected_bypass=false; real questions (technical, multi-domain, complex)",
      "none_trap": "expected_bypass=false; queries that LOOK trivial but aren't (e.g., short technical jargon)"
    }
  },
