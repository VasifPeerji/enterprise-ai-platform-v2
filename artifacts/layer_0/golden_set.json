  "_meta": {
    "name": "Layer 0 Fast Path — Golden Evaluation Set",
    "purpose": "Hand-curated multilingual + adversarial queries with ground-truth labels for Layer 0 bypass decisions. Used by scripts/benchmark_layer_0.py to compute precision, recall, latency, and per-category metrics.",
