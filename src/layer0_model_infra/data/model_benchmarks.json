    "ifeval":        {"primary_rubric": "output_structure",  "secondary_rubric": "task_count",        "description": "Tests strict instruction and format adherence"},
    "bbh":           {"primary_rubric": "reasoning_hops",    "secondary_rubric": "domain_depth",      "description": "Tests complex compositional reasoning"}
