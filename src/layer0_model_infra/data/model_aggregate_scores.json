{
  "_meta": {
    "schema_version": "1.0",
    "purpose": "Per-model aggregate benchmark scores used by the prior_quality() function in routing/aggregate_scores.py. Consumed whenever a model has fewer than the minimum number of per-question kNN outcomes (coverage_quality='low' OR neighbor outcomes < 3). Scores are normalised to [0, 1] regardless of the benchmark's native scale.",
    "sources": {
      "humaneval": "https://github.com/openai/human-eval — pass@1",
      "humaneval_plus": "https://github.com/evalplus/evalplus — pass@1",
      "mbpp": "https://huggingface.co/datasets/mbpp — pass@1",
      "swe_bench_verified": "https://www.swebench.com/ — verified split",
      "livecodebench": "https://livecodebench.github.io/ — pass@1 average across 4 cutoffs",
      "mmlu": "https://huggingface.co/datasets/cais/mmlu — 5-shot accuracy",
      "mmlu_pro": "https://huggingface.co/datasets/TIGER-Lab/MMLU-Pro — accuracy",
      "gpqa_diamond": "https://huggingface.co/datasets/Idavidrein/gpqa — pass rate",
      "math_hard": "https://github.com/openai/prm800k — accuracy on hard split",
      "gsm8k": "https://huggingface.co/datasets/gsm8k — accuracy",
      "bbh": "https://github.com/suzgunmirac/BIG-Bench-Hard — average accuracy",
      "ifeval": "https://huggingface.co/datasets/google/IFEval — instruction-following score",
      "livebench_coding": "https://livebench.ai — coding subset, average",
      "livebench_reasoning": "https://livebench.ai — reasoning subset, average",
      "mmmu": "https://mmmu-benchmark.github.io/ — multimodal accuracy",
      "mathvista": "https://mathvista.github.io/ — multimodal math accuracy",
      "arena_elo_normalised": "https://lmarena.ai — Arena Elo normalised to [0, 1] via (elo - 1000) / 500, clamped"
    },
    "missing_value_policy": "If a benchmark is absent for a model, the prior_quality() function simply omits it from the weighted average — the model is not penalised for lacking a score, but its weighted sum normalises against the benchmarks that ARE present.",
    "last_refresh": "2026-05-21",
    "refresh_cadence": "monthly via scripts/build_aggregate_scores.py (to be added in a later batch)"
  },

