{
  "_meta": {
    "name": "Layer 0 Paraphrase + OOD Corpus",
    "purpose": "Queries real ChatGPT/Claude/Gemini users type that lie outside our heuristic keyword table. Used to answer: does Model2Vec materially improve coverage beyond the heuristic baseline?",
    "version": "1.0.0",
    "selection_criteria": "Every paraphrased-trivial entry MUST be a phrase that (a) a real user would type, (b) is genuinely trivial chitchat, and (c) is NOT covered by the current _TOKEN_INDEX / phrase patterns. Every must-not-bypass entry sounds casual but contains a real question.",
    "scoring": {
      "true_positive": "bypass-eligible query the classifier correctly bypasses",
      "true_negative": "real question the classifier correctly does NOT bypass",
      "false_positive": "real question incorrectly bypassed (BAD — user gets a tiny model)",
      "false_negative": "trivial query incorrectly sent to full pipeline (acceptable — costs latency, not quality)"
    },
    "design_notes": "Heavily weighted toward false-positive testing since FP cost is high. Includes informal English, regional variants, mixed-script chitchat, and adversarial 'sounds-casual-but-isnt' cases."
  },
